@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<nav class="navbar navbar-expand-lg navbar-dark bg-success mb-4">
    <div class="container">
        <a class="navbar-brand" asp-area="Airline" asp-controller="Flights" asp-action="Index">
            Airline Portal
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#airlineNavbar"
                aria-controls="airlineNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="airlineNavbar">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link @(controller == "Flights" && action == "Index" ? "active" : "")"
                       asp-area="Airline" asp-controller="Flights" asp-action="Index">
                        Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(controller == "Flights" && action == "Manage" ? "active" : "")"
                       asp-area="Airline" asp-controller="Flights" asp-action="Manage">
                        Manage Flights
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(controller == "Flights" && action == "Regulation" ? "active" : "")"
                       asp-area="Airline" asp-controller="Flights" asp-action="Regulation">
                        Regulation
                    </a>
                </li>
            </ul>
            
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                        View Site
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container">
    @RenderBody()
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}