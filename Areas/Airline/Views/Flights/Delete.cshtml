@model Group5Flight.Models.Flight
@{
    ViewData["Title"] = "Delete Flight";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0">Delete Flight</h4>
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <h5>Are you sure you want to delete this flight?</h5>
            <p class="mb-0">This action cannot be undone.</p>
        </div>
        
        <table class="table table-borderless">
            <tr>
                <th style="width: 200px;">Flight Code</th>
                <td><strong>@Model.FlightCode</strong></td>
            </tr>
            <tr>
                <th>Route</th>
                <td>@Model.From to @Model.To</td>
            </tr>
            <tr>
                <th>Date</th>
                <td>@Model.Date.ToString("dddd, MMMM dd, yyyy")</td>
            </tr>
            <tr>
                <th>Departure Time</th>
                <td>@Model.DepartureTime.ToString("HH:mm")</td>
            </tr>
            <tr>
                <th>Arrival Time</th>
                <td>@Model.ArrivalTime.ToString("HH:mm")</td>
            </tr>
            <tr>
                <th>Airline</th>
                <td>@(Model.Airline?.Name ?? "N/A")</td>
            </tr>
            <tr>
                <th>Price</th>
                <td>$@Model.Price.ToString("F2")</td>
            </tr>
        </table>
        
        <hr />
        
        <form asp-action="DeleteConfirmed" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="FlightId" value="@Model.FlightId" />
            
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>