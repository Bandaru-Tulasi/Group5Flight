@model List<Group5Flight.Models.DomainModels.Flight>
@{
    ViewData["Title"] = "Airline Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Flight Management</h2>
    <a asp-action="Add" class="btn btn-success">Add New Flight</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <p class="mb-0">No flights available. Click "Add New Flight" to create one.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Flight Code</th>
                    <th>Airline</th>
                    <th>Route</th>
                    <th>Date</th>
                    <th>Departure</th>
                    <th>Arrival</th>
                    <th>Cabin</th>
                    <th>Price</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var flight in Model.OrderBy(f => f.Date).ThenBy(f => f.DepartureTime))
                {
                    <tr>
                        <td>@flight.FlightCode</td>
                        <td>@(flight.Airline?.Name ?? "N/A")</td>
                        <td>@flight.From to @flight.To</td>
                        <td>@flight.Date.ToString("MM/dd/yyyy")</td>
                        <td>@flight.DepartureTime.ToString("HH:mm")</td>
                        <td>@flight.ArrivalTime.ToString("HH:mm")</td>
                        <td>@flight.CabinType</td>
                        <td>$@flight.Price.ToString("F2")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@flight.FlightId" class="btn btn-primary btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@flight.FlightId" class="btn btn-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}