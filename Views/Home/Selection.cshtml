@model List<Group5Flight.Models.Flight>
@{
    ViewData["Title"] = "Selected Flights";
    var session = new Group5Flight.Models.FlightSession(Context.Session);
    var from = session.GetFrom();
    var to = session.GetTo();
    var date = session.GetDate();
    var cabinType = session.GetCabinType();
    var airlineId = session.GetAirlineId();
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">My Selected Flights</h4>
    </div>
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info">
                <p class="mb-0">You have no selected flights.</p>
            </div>
        }
        else
        {
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Airline</th>
                        <th>Flight Code</th>
                        <th>Route</th>
                        <th>Date</th>
                        <th>Departure</th>
                        <th>Arrival</th>
                        <th>Duration</th>
                        <th>Cabin</th>
                        <th>Price</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var flight in Model)
                    {
                        <tr>
                            <td>
                                @if (flight.Airline != null)
                                {
                                    <img src="~/images/@flight.Airline.ImageName" alt="@flight.Airline.Name" 
                                         style="max-width: 40px; max-height: 40px;" />
                                    <div class="small">@flight.Airline.Name</div>
                                }
                            </td>
                            <td>@flight.FlightCode</td>
                            <td>@flight.From to @flight.To</td>
                            <td>@flight.Date.ToString("MM/dd/yyyy")</td>
                            <td>@flight.DepartureTime.ToString("HH:mm")</td>
                            <td>@flight.ArrivalTime.ToString("HH:mm")</td>
                            <td>@flight.DurationDisplay</td>
                            <td>@flight.CabinType</td>
                            <td>$@flight.Price.ToString("F2")</td>
                            <td>
                                <form asp-action="Remove" method="post">
                                    <input type="hidden" name="id" value="@flight.FlightId" />
                                    <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        
        <hr />
        
        <div class="d-flex gap-2">
            <a asp-action="Index" 
               asp-route-from="@from"
               asp-route-to="@to"
               asp-route-departureDate="@date"
               asp-route-cabinType="@cabinType"
               asp-route-airlineId="@airlineId"
               class="btn btn-primary">
                Back to Home
            </a>
            
            @if (Model.Any())
            {
                <form asp-action="ClearAll" method="post" class="d-inline">
                    <button type="submit" class="btn btn-warning">Clear All Selections</button>
                </form>
            }
        </div>
    </div>
</div>