@using Group5Flight.Models
@{
    Layout = "_Layout";
    
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    
    var session = new FlightSession(Context.Session);
    int? count = session.GetSelectedFlightCount();
}

<nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
    <div class="container">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link @(controller == "Home" && action == "Index" ? "active" : "")"
                       asp-controller="Home" asp-action="Index">
                        Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(controller == "Home" && action == "Search" ? "active" : "")"
                       asp-controller="Home" asp-action="Search">
                        Search
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(controller == "Home" && action == "Privacy" ? "active" : "")"
                       asp-controller="Home" asp-action="Privacy">
                        Privacy
                    </a>
                </li>
            </ul>
            
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link" asp-area="Admin" asp-controller="Users" asp-action="Index">
                        Admin
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="Airline" asp-controller="Flights" asp-action="Index">
                        Airline
                    </a>
                </li>
                
                @if (count.HasValue && count > 0)
                {
                    <li class="nav-item">
                        <a class="nav-link @(controller == "Home" && action == "Selection" ? "active" : "")"
                           asp-controller="Home" asp-action="Selection">
                            Selection 
                            <span class="badge bg-danger rounded-pill">@count</span>
                        </a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link @(controller == "Home" && action == "Selection" ? "active" : "")"
                           asp-controller="Home" asp-action="Selection">
                            Selection
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<div class="container">
    @RenderBody()
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}